{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "query-filter/filter-group",
	"version": "0.2.0",
	"title": "Filter Group",
	"category": "theme",
	"icon": "filter",
	"description": "Container for filter blocks. Handles the query connection for all child filters and combines their queries.",
	"usesContext": [ "queryId", "query" ],
	"providesContext": {
		"query-filter/targetBlockId": "targetBlockId",
		"query-filter/targetBlockType": "targetBlockType"
	},
	"allowedBlocks": [
		"query-filter/taxonomy",
		"query-filter/search"
	],
	"supports": {
		"html": false,
		"className": true,
		"customClassName": true,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"layout": {
			"default": {
				"type": "flex",
				"flexWrap": "wrap"
			},
			"allowSwitching": true,
			"allowEditing": true,
			"allowInheriting": true,
			"allowVerticalAlignment": true
		},
		"interactivity": {
			"clientNavigation": true
		}
	},
	"attributes": {
		"targetBlockId": {
			"type": "string",
			"default": ""
		},
		"targetBlockType": {
			"type": "string",
			"default": ""
		}
	},
	"textdomain": "query-filter",
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
